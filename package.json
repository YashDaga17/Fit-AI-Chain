{
  "name": "fit-ai-chain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "setup": "bash scripts/setup.sh",
    "db:setup": "bash scripts/setup-db.sh",
    "db:studio": "dotenv -e .env.local -- npx drizzle-kit studio",
    "db:push": "dotenv -e .env.local -- npx drizzle-kit push",
    "db:generate": "dotenv -e .env.local -- npx drizzle-kit generate",
    "db:test": "node scripts/test-db-connection.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.1.0",
    "@onflow/react-sdk": "^0.20.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/pg": "^8.20.0",
    "@vercel/analytics": "^1.6.1",
    "@worldcoin/minikit-js": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.0",
    "lucide-react": "^0.544.0",
    "next": "15.5.9",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.6",
      "react-dom": "^19.2.6"
    }
  },
  "overrides": {
    "use-sync-external-store": "^1.5.0"
  }
